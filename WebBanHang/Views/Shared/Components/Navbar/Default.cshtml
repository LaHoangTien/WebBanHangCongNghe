@{
}
@model IEnumerable<Category>

<div class="left-sidebar">
	<h2>Category</h2>
	
		<div class="panel">
			<div class="panel-heading">
				
				@foreach (var item in Model)
				{
				<h3 class="panel-title grow"><a asp-controller="Home" asp-action="GetProductByCate" asp-route-Id="@item.Id">@item.Name</a></h3>
				}
			</div>
		</div>
</div>