@model IEnumerable<WebBanHang.Areas.Admin.Models.UserViewModel>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    Pager pager = new Pager();
    int pageNo = 0;
    if (ViewBag.Pager != null)
    {
        pager = ViewBag.Pager;
        pageNo = pager.Currentpage;
    }
}


<h1>Users</h1>
<table class="table">
    <thead>
        <tr>
            <th class="text-secondary">Name</th>
            <th class="text-secondary">Email</th>
            <th class="text-secondary">PhoneNumber</th>
            <th class="text-secondary">Address</th>
            <th class="text-secondary">Roles</th> <!-- Thêm cột Roles -->
            <th class="text-secondary">Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="text-secondary">@item.FullName</td>
                <td class="text-secondary">@item.Email</td>
                <td class="text-secondary">@item.PhoneNumber</td>
                <td class="text-secondary">@item.Address</td>
                <td class="text-secondary">
                    @foreach (var role in item.Roles)
                    {
                        <span class="text-secondary" class="badge badge-primary">@role</span>
                    }
                </td> <!-- Hiển thị các role -->
                <td class="text-secondary">
                    <a asp-controller="UserManager" asp-action="EditUserRole" asp-route-userId="@item.Id">Edit Roles</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<section class="pager">
    <div class="container">
        @if (pager.TotalPages > 0)
        {
            <ul class="pagination justify-content-center">
                @* First and Previous Buttons *@
                <li class="page-item @(pager.Currentpage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-controller="UserManager" asp-action="Index" asp-route-pg="1" tabindex="-1" aria-disabled="@(pager.Currentpage == 1)">First</a>
                </li>
                <li class="page-item @(pager.Currentpage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-controller="UserManager" asp-action="Index" asp-route-pg="@(pager.Currentpage > 1 ? pager.Currentpage - 1 : 1)" tabindex="-1" aria-disabled="@(pager.Currentpage == 1)">Previous</a>
                </li>

                @* Page Numbers *@
                @for (var pge = pager.StartPage; pge <= pager.EndPage; pge++)
                {
                    @if (pge > 0) // Chỉ hiển thị các số trang dương
                    {
                        <li class="page-item @(pge == pager.Currentpage ? "active" : "")">
                            <a class="page-link" asp-controller="UserManager" asp-action="Index" asp-route-pg="@pge">@pge</a>
                        </li>
                    }
                }

                @* Next and Last Buttons *@
                <li class="page-item @(pager.Currentpage == pager.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-controller="UserManager" asp-action="Index" asp-route-pg="@(pager.Currentpage < pager.TotalPages ? pager.Currentpage + 1 : pager.TotalPages)" tabindex="-1" aria-disabled="@(pager.Currentpage == pager.TotalPages)">Next</a>
                </li>
                <li class="page-item @(pager.Currentpage == pager.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-controller="UserManager" asp-action="Index" asp-route-pg="@(pager.TotalPages)" tabindex="-1" aria-disabled="@(pager.Currentpage == pager.TotalPages)">Last</a>
                </li>
            </ul>

            @* Page Info *@
            <p class="text-center">
                Page @pager.Currentpage of @pager.TotalPages
            </p>
        }
    </div>
</section>
