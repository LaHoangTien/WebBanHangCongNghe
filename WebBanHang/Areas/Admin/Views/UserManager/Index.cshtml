@section Scripts {
    <script>
        $('#editRoleModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget); // Button that triggered the modal
            var userId = button.data('userid'); // Extract info from data-* attributes
            var modal = $(this);

            // Load user roles
            $.ajax({
                url: '@Url.Action("GetUserRoles", "UserManager")',
                type: 'GET',
                data: { userId: userId },
                success: function (data) {
                    $('#UserId').val(data.userId);
                    var rolesSelect = $('#SelectedRoles');
                    rolesSelect.empty();
                    $.each(data.allRoles, function (i, role) {
                        rolesSelect.append($('<option>', {
                            value: role,
                            text: role,
                            selected: $.inArray(role, data.userRoles) !== -1
                        }));
                    });
                }
            });
        });

        $('#editRoleForm').submit(function (event) {
            event.preventDefault();
            $.ajax({
                url: '@Url.Action("EditUserRole", "UserManager")',
                type: 'POST',
                data: $(this).serialize(),
                success: function () {
                    $('#editRoleModal').modal('hide');
                    // Optionally, update the UI or show a success message
                },
                error: function () {
                    // Handle error
                }
            });
        });
    </script>
}

