@model WebBanHang.Models.Product
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2 style="text-align:center">Thông Tin Sản Phẩm</h2>
 
<form method="post">

    <div class=" container">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <box >
                    <h1 class="text-dark-50">@Model.Name</h1>
                <div style ="max-width: 500px; align-items:center"> <img src="@Model.ImageUrl" alt="Product Image" /></div>
                   
               
                    
                    <h5>Chi tiết sản phẩm</h5>

                    <h6 class="text-muted">@Model.Description</h6>
                    <div class="col-12 col-md-6 pb-1">
                        <h5 class="text-danger h2 pb-2">Giá: @Model.Price.ToString("c")</h5>
                    </div>
                
            </box>
        }
    </div>
</form>



