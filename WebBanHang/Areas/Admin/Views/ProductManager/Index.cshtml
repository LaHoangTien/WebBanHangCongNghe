@model IEnumerable<WebBanHang.Models.Product>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    Pager pager = new Pager();
    int pageNo = 0;
    if (ViewBag.Pager != null)
    {
        pager = ViewBag.Pager;
        pageNo = pager.Currentpage;
    }
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
<h2>Sản Phẩm</h2>

<div class="row">
    <div class="col-sm-9">
        <a asp-controller="ProductManager" asp-action="Add" class="btn btn-primary"><i class="bi bi-plus-square"></i> Add Products</a>
    </div>
    <div class="col-sm-3">
        <div class="search_box">
            <form asp-action="SearchProduct" asp-controller="ProductManager" method="get" class="form-inline my-2 my-lg-0">
                <input class="form-control mr-sm-2" style="width:250px;background-image: url(../images/home/searchicon.png);background-repeat: no-repeat;background-position: 225px;" type="search" name="searchString" value="@ViewBag.SearchString" placeholder="Search" aria-label="Search">
            </form>
        </div>
       @*  <div class="search_box">
            <div style="display: flex;">
                <form asp-action="SearchProduct" asp-controller="ProductManager" method="get" class="form-inline my-2 my-lg-0">
                    <input class="form-control border mr-sm-2" type="search" name="searchString" value="@ViewBag.SearchString" placeholder="Search" aria-label="Search">
                    <button class="btn btn-outline-warning my-2 my-sm-0" type="submit">Search</button>
                </form>
            </div>
        </div> *@
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th><a asp-action="Search" asp-controller="Product" asp-route-sortOrder="name_asc">Name <i class="bi bi-arrow-down-up"></i></a></th>
            <th><a asp-action="Search" asp-controller="Product" asp-route-sortOrder="price_desc">Price <i class="bi bi-arrow-down-up"></i></a></th>
            <th>CostPrice</th>
            <th>Description</th>
            <th>Stock</th>
            <th>Category</th>
            <th>Brand</th>
            <th>Image</th>
           
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.Price.ToString("#,##đ")</td>
                <td>@product.CostPrice.ToString("#,##đ")</td>
                <td class="des">@product.Description</td>
                <td>@product.Stock</td>
                <td>@product.Category?.Name</td>
                <td>@product.Brand?.Name</td>
                <td><img src="@product.ImageUrl" style="max-width: 100px;" /></td>
                <td class="btn-group" role="group" aria-label="Basic example">
                    <a asp-action="Display" class="btn btn-primary btn-sm" asp-route-id="@product.Id">View</a> |
                    <a asp-action="Update" class="btn btn-primary btn-sm" asp-route-id="@product.Id">Edit</a> |
                    <a asp-action="Delete" class="btn btn-primary btn-sm" asp-controller="ProductManager" asp-route-id="@product.Id">Delete</a>
                </td>
            </tr>
        }
       
    </tbody>
</table>

<section class="pager">
<div class="container">
    @if (pager.TotalPages > 0)
    {
        <ul class="pagination justify-content-center">
            @* First and Previous Buttons *@
            <li class="page-item @(pager.Currentpage == 1 ? "disabled" : "")">
                <a class="page-link" asp-controller="ProductManager" asp-action="Index" asp-route-pg="1" tabindex="-1" aria-disabled="@(pager.Currentpage == 1)">First</a>
            </li>
            <li class="page-item @(pager.Currentpage == 1 ? "disabled" : "")">
                <a class="page-link" asp-controller="ProductManager" asp-action="Index" asp-route-pg="@(pager.Currentpage > 1 ? pager.Currentpage - 1 : 1)" tabindex="-1" aria-disabled="@(pager.Currentpage == 1)">Previous</a>
            </li>

            @* Page Numbers *@
            @for (var pge = pager.StartPage; pge <= pager.EndPage; pge++)
            {
                @if (pge > 0) // Chỉ hiển thị các số trang dương
                {
                    <li class="page-item @(pge == pager.Currentpage ? "active" : "")">
                        <a class="page-link" asp-controller="ProductManager" asp-action="Index" asp-route-pg="@pge">@pge</a>
                    </li>
                }
            }

            @* Next and Last Buttons *@
            <li class="page-item @(pager.Currentpage == pager.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-controller="ProductManager" asp-action="Index" asp-route-pg="@(pager.Currentpage < pager.TotalPages ? pager.Currentpage + 1 : pager.TotalPages)" tabindex="-1" aria-disabled="@(pager.Currentpage == pager.TotalPages)">Next</a>
            </li>
            <li class="page-item @(pager.Currentpage == pager.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-controller="ProductManager" asp-action="Index" asp-route-pg="@(pager.TotalPages)" tabindex="-1" aria-disabled="@(pager.Currentpage == pager.TotalPages)">Last</a>
            </li>
        </ul>

        @* Page Info *@
        <p class="text-center">
            Page @pager.Currentpage of @pager.TotalPages
        </p>
    }
</div>
</section>
