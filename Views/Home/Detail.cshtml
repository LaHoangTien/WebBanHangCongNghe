</style>

<style>
	.star-rating {
		direction: rtl;
		display: inline-block;
		font-size: 0;
	}

		.star-rating input[type="radio"] {
			display: none;
		}

		.star-rating label {
			font-size: 2rem;
			color: lightgray;
			cursor: pointer;
		}

		.star-rating input[type="radio"]:checked ~ label {
			color: #fb9372;
		}

		.star-rating label:hover,
		.star-rating label:hover ~ label {
			color: #fb9372;
		}

	.fa-star, .fa-star-half-alt, .fa-star-o {
		color: #fb9372;
	}

	.rating-stars, .average-rating {
		display: inline-block;
		font-size: 25px;
	}
<style>
	.avatar {
		vertical-align: middle;
		width: 50px;
		height: 50px;
		border-radius: 50%;
	}



	.card {
		border: none;
		box-shadow: 5px 6px 6px 2px #e9ecef;
